# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# =========================
# DEPENDENCIES (Thư viện)
# =========================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# =========================
# NEXT.JS & BUILD
# =========================
/.next/
/out/
/build
/.turbo/

# =========================
# TESTING & DEBUG
# =========================
/coverage
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# =========================
# OS & MISC (Rác hệ điều hành)
# =========================
.DS_Store
Thumbs.db
*.pem

# =========================
# BẢO MẬT & MÔI TRƯỜNG
# =========================
# Bỏ qua tất cả các file chứa biến môi trường nhạy cảm
.env*
# NHƯNG cho phép đẩy file mẫu lên để dễ setup lại sau này
!.env.example

# =========================
# DEPLOYMENT
# =========================
.vercel

# =========================
# TYPESCRIPT
# =========================
*.tsbuildinfo
next-env.d.ts

# =========================
# PRISMA & DATABASE
# =========================
/app/generated/prisma
/prisma/*.db
/prisma/*.db-journal

# =========================
# IDE & EDITORS (Trình soạn thảo)
# =========================
.vscode/
.cursor/
.idea/
*.swp